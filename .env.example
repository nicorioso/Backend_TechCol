# TechCol backend environment example
# Copy these values into your local environment or hosting provider secrets.

# Database
BD_URL=jdbc:mysql://localhost:3306/techcop_db_dev?useSSL=false&serverTimezone=UTC
BD_USERNAME=techcop_admin
BD_PASSWORD=change_this_password

# Mail
MAIL_USERNAME=soporte.techcop@gmail.com
MAIL_PASSWORD=app_password_here

# Twilio
TWILIO_ID=AC1234567890abcdef1234567890abcd
TWILIO_TOKEN=1234567890abcdef1234567890abcdef
TWILIO_NUMBER=+14155552671

# Google OAuth
GOOGLE_CLIENT_ID=123456789012-ab1234cd5678ef90gh12ij34kl56mn78.apps.googleusercontent.com

# JWT
JWT_SECRET=replace_with_a_long_random_secret

# PayPal
PAYPAL_ID=paypal_client_id_here
PAYPAL_SECRET=paypal_client_secret_here
PAYPAL_RETURN_URL=http://localhost:8080/api/paypal/return
PAYPAL_CANCEL_URL=http://localhost:8080/api/paypal/cancel
PAYPAL_FRONTEND_RETURN_URL=https://frontendtechcol-production.up.railway.app/checkout
PAYPAL_FRONTEND_CANCEL_URL=https://frontendtechcol-production.up.railway.app/checkout

# reCAPTCHA
RECAPTCHA_SITE_KEY=6Lxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RECAPTCHA_SECRET_KEY=6Lyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# Security
REFRESH_COOKIE_SECURE=false

# CORS
CORS_ALLOWED_ORIGINS=https://frontendtechcol-production.up.railway.app,http://localhost:3000,http://localhost:4200,http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOWED_ORIGIN_PATTERNS=
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS,HEAD
CORS_ALLOWED_HEADERS=*
CORS_EXPOSED_HEADERS=Authorization,X-Total-Count,X-Page-Number,X-Page-Size
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=3600
