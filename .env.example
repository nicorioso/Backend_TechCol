# ==============================================================================
# TechCol - Plantilla de Variables de Entorno
# ==============================================================================
# IMPORTANTE: Este proyecto lee las variables directamente del entorno.
# Configura estas variables en tu IDE (ej. IntelliJ > Edit Configurations > Environment variables).
#
# Los valores a continuación son EJEMPLOS de cómo debe lucir la información.
# Solicita las credenciales reales al equipo.
# ==============================================================================

# --- Base de Datos (MySQL) ---
# Formato: jdbc:mysql://[host]:[puerto]/[nombre_bd]
BD_URL=jdbc:mysql://localhost:3306/techcop_db_dev?useSSL=false&serverTimezone=UTC
BD_USERNAME=techcop_admin
BD_PASSWORD=SuperSecretPassw0rd2026!

# --- Correo Electrónico (Gmail SMTP) ---
# Usa una "Contraseña de Aplicación" de Google (16 caracteres sin espacios), no la clave normal
MAIL_USERNAME=soporte.techcop@gmail.com
MAIL_PASSWORD=abcd efgh ijkl mnop

# --- Integración con Twilio ---
# El Account SID siempre empieza con "AC" seguido de 32 caracteres hexadecimales
TWILIO_ID=AC1a2b3c4d5e6f7g8h9i0j1k2l3m4n5o6p
TWILIO_TOKEN=1234567890abcdef1234567890abcdef
TWILIO_NUMBER=+14155552671

# --- Autenticación Google ---
# Formato: [numeros]-[letrasynumeros].apps.googleusercontent.com
GOOGLE_CLIENT_ID=123456789012-ab1234cd5678ef90gh12ij34kl56mn78.apps.googleusercontent.com

# --- Seguridad (JWT) ---
# Cadena alfanumérica larga y segura para firmar los tokens (ej. SHA-256 o superior)
JWT_SECRET=v9y$B&E)H@McQfTjWnZr4u7x!z%C*F-JaNdRgUkXp2s5v8y/B?E(G+KbPeShVmYq

# --- PayPal ---
# Cadenas largas proporcionadas por el panel de desarrolladores de PayPal
PAYPAL_ID=AcelXyZ12345_AbCdEfGhIjKlMnOpQrStUvWxYz0987654321_ExampleID
PAYPAL_SECRET=EN_SecretKey_0987654321_AbCdEfGhIjKlMnOpQrStUvWxYz12345_Example